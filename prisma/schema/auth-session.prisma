model AuthSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}
