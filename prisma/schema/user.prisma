enum Role {
  ADMIN
  REGULAR
  BEGINNER
}

model User {
  id                  Int                 @id @default(autoincrement())
  email               String              @unique
  password            String
  name                String
  role                Role                @default(BEGINNER)
  isActive            Boolean             @default(true)
  agreedTermsAt       DateTime?
  agreedPrivacyAt     DateTime?
  createdAt           DateTime            @default(now())
  memberships         UserSemesterTrack[]
  sentInvitations     Invitation[]        @relation("InvitationInvitedBy")
  acceptedInvitations Invitation[]        @relation("InvitationAcceptedUser")
  authSessions        AuthSession[]

  @@map("users")
}
